APP_ENV=prod
APP_URL=https://example.com/certinel/public
APP_SECRET=change-me-to-a-long-random-string

DB_HOST=localhost
DB_NAME=certinel
DB_USER=certinel_user
DB_PASS=change-me

# Email outbound
MAIL_FROM=certinel@example.com
MAIL_FROM_NAME=Certinel
MAIL_TRANSPORT=mail

# SMTP (MAIL_TRANSPORT=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMTP_ENCRYPTION=starttls
SMTP_TIMEOUT_SECS=10

# HTTP API hook (MAIL_TRANSPORT=api)
MAIL_API_URL=
MAIL_API_TOKEN=

# Admin notifications (cron failure, etc.)
ADMIN_EMAIL=admin@example.com

# API keys ownership (v0.5.6)
# Default false: existing keys remain system-scoped; ownership enforced only for user-scoped keys.
API_KEYS_REQUIRE_OWNER=false

# Legacy worker API key fallback (v0.4 also supports scoped DB API keys)
API_WORKER_KEY=change-me-too

# TLS fetch
TLS_CONNECT_TIMEOUT_SECS=7
TLS_READ_TIMEOUT_SECS=7
TLS_SAMPLES_ON_CHANGE=2

# v0.7.3: TLS trust validation probe (used only when monitor_settings.tls_validation_mode != off)
# CertFetcher still uses verify_peer=false to observe the served certificate.
TLS_TRUST_CONNECT_TIMEOUT_SECS=4
TLS_TRUST_TIMEOUT_SECS=6
# Optional: CA bundle path override (when empty, system/default CA bundle is used)
TLS_CA_BUNDLE=

# SSRF policy framework (v0.5)
#
# Modes:
# - legacy (default): preserve v0.4.x behavior (no SSRF blocking)
# - public_only: block private/reserved IP ranges
# - allowlist_private: block private/reserved unless allowlisted
SSRF_MODE=legacy

# Optional allowlists (comma-separated). Empty = none.
# - SSRF_ALLOW_CIDRS: CIDRs and/or single IPs (e.g. 10.0.0.0/8, 192.168.1.10)
# - SSRF_ALLOW_HOSTS: exact hostnames or suffixes via ".example.com" or "*.example.com"
# - SSRF_ALLOW_PORTS: allowed destination ports (e.g. 443,8443)
SSRF_ALLOW_CIDRS=
SSRF_ALLOW_HOSTS=
SSRF_ALLOW_PORTS=

# Webhook egress hardening (v0.5.1)
#
# Modes:
# - legacy (default): preserve v0.4.x behavior (no blocking)
# - public_only: require https and block private/reserved IP ranges
# - allowlist: require https and allow private/reserved only if allowlisted via SSRF_ALLOW_* above
WEBHOOK_MODE=legacy

# RSS tenancy hardening (v0.5.2)
# Default false: non-admin RSS tokens only see events for monitors they own (no system/global events).
# Admin/auditor RSS tokens may include system/global events only if enabled here.
RSS_INCLUDE_SYSTEM_EVENTS=false
# Registration/bootstrap hardening (v0.5.3)
#
# REGISTRATION_MODE:
# - open (default): anyone can register
# - invite: registration requires SETUP_ADMIN_TOKEN (shared out-of-band)
# - closed: registration disabled
REGISTRATION_MODE=open
#
# Optional: require this token during first registration to claim the first admin.
# In REGISTRATION_MODE=invite, the same token is required for all registrations.
SETUP_ADMIN_TOKEN=
#
# NOTE: ADMIN_EMAIL is used for admin notifications (cron failure, etc.).
# In v0.5.3, if ADMIN_EMAIL is set on a fresh install (no users yet),
# only that email is allowed to claim the first admin at registration time.

# Error detail mode (v0.5.4)
# - safe (default): unauthenticated error pages show only a correlation id
# - full: include config/DB details on error pages (not recommended for public instances)
ERROR_DETAIL_MODE=safe

# Session/cookie hardening for reverse proxy deployments (v0.5.5)
#
# TRUST_PROXY_HEADERS:
# - false (default): rely on direct HTTPS detection only (same behavior as v0.5.4 and earlier)
# - true: honor proxy headers (X-Forwarded-Proto, Forwarded) to detect HTTPS, gated by TRUSTED_PROXY_CIDRS
TRUST_PROXY_HEADERS=false
# Optional comma-separated CIDRs/IPs identifying trusted proxies.
# If TRUST_PROXY_HEADERS=true and TRUSTED_PROXY_CIDRS is empty, any proxy is trusted.
TRUSTED_PROXY_CIDRS=
# Force Secure cookies even if HTTPS detection fails (useful in some terminated-TLS setups).
FORCE_SECURE_COOKIES=false

# Coarse rate limiting (v0.5.7)
#
# Defaults are intentionally high.
# Set max<=0 or window<=0 to disable a limiter.
# Login (per source IP)
RATE_LIMIT_LOGIN_MAX=60
RATE_LIMIT_LOGIN_WINDOW_SEC=900
# API (per IP and per Bearer token) for /api/v1/*
RATE_LIMIT_API_IP_MAX=600
RATE_LIMIT_API_IP_WINDOW_SEC=60
RATE_LIMIT_API_TOKEN_MAX=1200
RATE_LIMIT_API_TOKEN_WINDOW_SEC=60

# Baseline security headers (v0.5.8)
#
# CSP:
# - report_only (default): sends Content-Security-Policy-Report-Only
# - enforce: sends Content-Security-Policy (can break UI if too strict)
# - off: disables CSP headers
CSP_MODE=report_only
# Default CSP is permissive to avoid breaking the UI (allows inline script/style).
CSP_POLICY=default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
# Optional: append report endpoint to CSP as `report-uri <url>`
CSP_REPORT_URI=

# HSTS (sent only when HTTPS is confirmed; includes proxy mode from v0.5.5)
HSTS_ENABLED=true
HSTS_MAX_AGE=15552000
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false

# Snapshot retention (v0.7.7 safeguards)
# SNAPSHOT_RETENTION_DAYS: delete snapshots older than N days (0=disabled, default 90).
# SNAPSHOT_KEEP_PER_MONITOR: always keep at least N newest snapshots per monitor (default 10).
SNAPSHOT_RETENTION_DAYS=90
SNAPSHOT_KEEP_PER_MONITOR=10

